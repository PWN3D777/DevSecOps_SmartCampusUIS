# ADMIN DATABASE VARIABLES
POSTGRESQL_PORT=5432
POSTGRESQL_USER=postgres
POSTGRESQL_PASSWORD=IoTPass1234
POSTGRESQL_DB=iot

# ADMIN SERVICE VARIABLES
ADMIN_SERVICE_PORT=8081

# DATA SERVICE VARIABLES
DATA_SERVICE_PORT=8082

# RabbitMQ configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=dataUser
RABBITMQ_PASSWORD=dataPass

# MQTT / EMQX configuration
MQTT_BROKER_URL=tcp://emqx:1883
MQTT_BROKER_CLIENT_ID=dataService
TOPIC_LISTENER=smartCampus/#

# InfluxDB configuration
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=smartcampusuis-iot-auth-token
INFLUXDB_ORG=uis
INFLUXDB_BUCKET=iotuis

# MongoDB configuration
MONGO_HOST=mongo
MONGO_DATABASE=iotData
MONGO_AUTH_DB=admin
MONGO_USERNAME=mongoUser
MONGO_PASSWORD=mongoPass

# MinIO configuration
MINIO_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=data-bucket

# GATEWAY SERVICE VARIABLES
GATEWAY_PORT=8080
